        "pivotReason": "Thick oils should not use roll-on — ball won't spin. Recommend Tola or Dropper."
      }
    },
    {
      "id": "viscosity-edp-no-rollon",
      "category": "viscosity_guard",
      "question": "I'm making an eau de parfum. Should I use roll-on bottles?",
      "expect": {
        "mustMentionAny": ["spray", "sprayer", "atomizer", "mist", "leak"],
        "shouldPivot": true,
        "pivotReason": "Alcohol-based EDPs leak through roll-on applicators. Recommend spray/atomizer."
      }
    },
    {
      "id": "viscosity-lotion-no-dropper",
      "category": "viscosity_guard",
      "question": "I'm packaging a thick body lotion. Would a dropper bottle work?",
      "expect": {
        "mustMentionAny": ["pump", "lotion pump"],
        "shouldPivot": true,
        "pivotReason": "Thick emulsions need lotion pump, not dropper."
      }
    },
