{
  "version": "2.0",
  "description": "Grace AI retrieval accuracy eval — product lookup, component matching, hallucination detection, policy, brand guardrails",
  "cases": [
    {
      "id": "exact-boston-30ml",
      "category": "exact_retrieval",
      "question": "Do you have a 30ml Boston Round bottle?",
      "expect": {
        "mustMention": ["Boston Round", "30ml"],
        "mustNotMention": ["don't stock", "don't carry", "not available"],
        "expectedTools": ["searchCatalog"],
        "expectedFamily": "Boston Round",
        "expectedCapacityMl": 30
      }
    },
